# ===========================================
# Money Saathi — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# ---------- Required ----------

# PostgreSQL connection string (Supabase, Neon, local, etc.)
DATABASE_URL=postgresql://postgres:oGwj5hjnwMSzXyHg@db.oszllmgzhegnbyazafhr.supabase.co:5432/postgres

# Session signing secret (32+ random characters recommended)
# If not set, a random secret is generated on each server restart
# which will invalidate all existing sessions.
SESSION_SECRET=your-random-secret-here-at-least-32-chars

# ---------- Optional ----------

# OpenAI API key for the "Ask Money Saathi AI" chat feature.
# Without this, the AI chat feature will show an error when used.
# Supports standard OpenAI or any OpenAI-compatible provider.
OPENAI_API_KEY=sk-...

# Custom OpenAI-compatible base URL (defaults to https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Restrict CORS origins (comma-separated). Defaults to reflecting request origin.
# CORS_ORIGIN=https://your-app.vercel.app

# Server port (defaults to 8080)
# PORT=8080

# Frontend dev server port (defaults to 5173)
# Only used in development. In production, the frontend is built as static files.
# VITE_PORT=5173

# Node environment
# NODE_ENV=production

# ---------- Replit-specific (auto-set on Replit) ----------
# These are set automatically when running on Replit.
# You do NOT need to set them for local or Vercel deployment.

# REPL_ID=...
# BASE_PATH=/
# AI_INTEGRATIONS_OPENAI_API_KEY=...
# AI_INTEGRATIONS_OPENAI_BASE_URL=...
