modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["bash", "-c", "pnpm install && BASE_PATH=/ pnpm --filter @workspace/money-saathi-v1 run build && pnpm --filter @workspace/api-server run build && cp -r artifacts/money-saathi-v1/dist/public artifacts/api-server/dist/public"]
run = ["bash", "-c", "NODE_ENV=production node artifacts/api-server/dist/index.mjs"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
