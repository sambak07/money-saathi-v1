modules = ["nodejs-24"]

run = "cd artifacts/money-saathi-v1 && pnpm dev"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["bash", "-c", "pnpm install && cd artifacts/money-saathi-v1 && pnpm build"]
run = ["bash", "-c", "cd artifacts/money-saathi-v1 && pnpm preview"]

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 80

[userenv]

[userenv.production]
SUPABASE_DATABASE_URL = "postgresql://postgres:MyP@ss#2026@db.oszllmgzhegnbyazafhr.supabase.co:5432/postgres"
