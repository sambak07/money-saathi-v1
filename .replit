modules = ["nodejs-24", "postgresql-16"]

run = "npx tsx artifacts/api-server/src/index.ts"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "npx tsx artifacts/api-server/src/index.ts"]
build = ["bash", "-c", "pnpm install && pnpm -r run build"]

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
