modules = ["nodejs-24", "postgresql-16"]

run = "npx tsx artifacts/api-server/src/index.ts"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "npx tsx artifacts/api-server/src/index.ts"]
build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/money-saathi-v1 run build && pnpm --filter @workspace/api-server run build && cp -r artifacts/money-saathi-v1/dist/public artifacts/api-server/dist/public"]

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
SUPABASE_DATABASE_URL = "postgres://postgres:MyP%40ss%232026@db.oszllmgzhegnbyazafhr.supabase.co:6543/postgres?sslmode=require"
