modules = ["nodejs-24"]

run = "pnpm --filter ./artifacts/money-saathi-v1 dev"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["bash", "-c", "pnpm install && pnpm --filter ./artifacts/money-saathi-v1 build"]
run = ["bash", "-c", "cd artifacts/money-saathi-v1 && node serve.js"]

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 80
